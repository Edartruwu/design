{
  "extends": "../../../tooling/tsconfig/base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["./**/*.ts"]
}
