{
  "name": "@inedge/designer",
  "version": "0.0.0",
  "description": "React canvas design library — frames, layers, actions, units. Composable, type-safe, performant at 120 Hz drag.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": {
        "import": "./dist/ui.d.ts",
        "require": "./dist/ui.d.cts"
      },
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs",
      "default": "./dist/ui.js"
    },
    "./components": {
      "types": {
        "import": "./dist/ui.d.ts",
        "require": "./dist/ui.d.cts"
      },
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs",
      "default": "./dist/ui.js"
    },
    "./utils": {
      "types": {
        "import": "./dist/utils.d.ts",
        "require": "./dist/utils.d.cts"
      },
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.js"
    },
    "./static": {
      "types": {
        "import": "./dist/static.d.ts",
        "require": "./dist/static.d.cts"
      },
      "import": "./dist/static.js",
      "require": "./dist/static.cjs",
      "default": "./dist/static.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench --run",
    "test:type": "vitest --typecheck --run"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "alien-signals": "^2.0.0",
    "clsx": "^2.1.1",
    "mutative": "^1.0.0",
    "tailwind-merge": "^2.6.0",
    "use-sync-external-store": "^1.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^0.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.17.0",
    "typescript": "~6.0.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "react",
    "canvas",
    "design",
    "designer",
    "editor",
    "figma",
    "signals",
    "alien-signals",
    "zustand",
    "mutative"
  ]
}
